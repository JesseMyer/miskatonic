# ============================================================
# MISKATONIC GOVERNANCE ANNOTATIONS
# msk: namespace carries platform-specific metadata
# These do not modify TOGAF semantics.
# They annotate constructs with Miskatonic operational context.
# ============================================================

msk:togafDomain
    a owl:AnnotationProperty ;
    rdfs:label "TOGAF Domain" ;
    rdfs:comment "The TOGAF architecture domain this construct belongs to." .

msk:togafSubDomain
    a owl:AnnotationProperty ;
    rdfs:label "TOGAF Sub-Domain" ;
    rdfs:comment "The sub-domain within the TOGAF architecture domain." .

msk:figureRef
    a owl:AnnotationProperty ;
    rdfs:label "Figure Reference" ;
    rdfs:comment "The TOGAF 9.2 chapter 30 figure that declares this construct or relationship." .

msk:miskatonicPrimary
    a owl:AnnotationProperty ;
    rdfs:label "Miskatonic Primary Construct" ;
    rdfs:comment "True if this construct appears as a primary TOGAF construct in the Miskatonic Ossuary M&A corpus frontmatter." .

msk:miskatonicNote
    a owl:AnnotationProperty ;
    rdfs:label "Miskatonic Governance Note" ;
    rdfs:comment "Platform-specific governance note for this construct within Miskatonic." .

msk:sourceNote
    a owl:AnnotationProperty ;
    rdfs:label "Source Note" ;
    rdfs:comment "Notes deviations from TOGAF 9.2 as published, inherited from cadmiumkitty v2.0.0 or introduced by Miskatonic." .

msk:forkGovernanceRef
    a owl:AnnotationProperty ;
    rdfs:label "Fork Governance Reference" ;
    rdfs:comment "URI of the FORK-GOVERNANCE.md document for this fork." .

msk:phaseIntroduced
    a owl:AnnotationProperty ;
    rdfs:label "Miskatonic Phase Introduced" ;
    rdfs:comment "The Miskatonic build phase in which this artifact was introduced." .

msk:knownGaps
    a owl:AnnotationProperty ;
    rdfs:label "Known Gaps" ;
    rdfs:comment "Documented gaps between this fork and the complete TOGAF 9.2 specification." .
